name: "ChinaIPs"
desc: "ChinaIPs分流规则"

rule-providers:
  ChinaIPs:
    type: http
    behavior: ipcidr
    url: "https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/rule/Clash/ChinaIPs/ChinaIPs_IP.yaml"
    path: ./ruleset/ChinaIPs_IP.yaml
    interval: 86400

rules:
  - RULE-SET,ChinaIPs,DIRECT
